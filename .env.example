# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# cp .env.example .env

APP_ENV=development          # development | staging | production
APP_PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_dev
DB_USER=postgres
DB_PASSWORD=your_password_here   # ← 실제 비밀번호로 교체

API_KEY=your_api_key_here        # ← 실제 API 키로 교체